    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const data = json.data || {};",
                  "pm.collectionVariables.set('accessToken', data.accessToken || '');",
                  "pm.collectionVariables.set('refreshToken', data.refreshToken || '');",
                  "pm.collectionVariables.set('sessionId', data.sessionId || '');",
                  "pm.collectionVariables.set('currentUserId', data.user?.id || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/auth/login",
              "host": ["{{apiBase}}"],
              "path": ["auth", "login"]
            },
            "description": "Run this first. Saves `accessToken`, `refreshToken`, `sessionId`, and `currentUserId` into collection variables."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const data = json.data || {};",
                  "pm.collectionVariables.set('accessToken', data.accessToken || pm.collectionVariables.get('accessToken'));",
                  "pm.collectionVariables.set('refreshToken', data.refreshToken || pm.collectionVariables.get('refreshToken'));",
                  "pm.collectionVariables.set('sessionId', data.sessionId || pm.collectionVariables.get('sessionId'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/auth/refresh",
              "host": ["{{apiBase}}"],
              "path": ["auth", "refresh"]
            }
          }
        },
        {
          "name": "Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/auth/me",
              "host": ["{{apiBase}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('resetToken', json.data?.resetToken || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/auth/forgot-password",
              "host": ["{{apiBase}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Demo flow returns `resetToken` in the response and saves it into collection variables."
          }
        },
        {
          "name": "Reset Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.collectionVariables.set('ownerPassword', pm.collectionVariables.get('ownerResetPassword'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"{{ownerResetPassword}}\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/auth/reset-password",
              "host": ["{{apiBase}}"],
              "path": ["auth", "reset-password"]
            },
            "description": "Updates `ownerPassword` to the reset password so later login requests keep working."
          }
        },
        {
          "name": "Change Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.collectionVariables.set('ownerPassword', pm.collectionVariables.get('ownerOriginalPassword'));",
                  "pm.collectionVariables.set('accessToken', '');",
                  "pm.collectionVariables.set('refreshToken', '');",
                  "pm.collectionVariables.set('sessionId', '');"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{ownerResetPassword}}\",\n  \"newPassword\": \"{{ownerOriginalPassword}}\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/auth/change-password",
              "host": ["{{apiBase}}"],
              "path": ["auth", "change-password"]
            },
            "description": "Use this after logging in with the reset password. It restores the original owner password and clears current auth variables because all sessions are invalidated."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/auth/logout",
              "host": ["{{apiBase}}"],
              "path": ["auth", "logout"]
            },
            "description": "Usually run this last because it invalidates the current session."
          }
        }
      ]
    },
