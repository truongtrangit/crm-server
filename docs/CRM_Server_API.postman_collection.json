{
  "info": {
    "name": "CRM Server API",
    "_postman_id": "crm-server-v1",
    "description": "Full API collection for CRM Server — Base URL: http://localhost:4000/api/v1\n\n## Setup\n1. Run **Auth / Login** first\n2. The `accessToken` collection variable is set automatically via the test script\n3. All subsequent requests use `{{accessToken}}` in the Authorization header",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:4000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken","value": "", "type": "string" },
    { "key": "sessionId",   "value": "", "type": "string" },
    { "key": "userId",      "value": "USER001", "type": "string" },
    { "key": "customerId",  "value": "CUST001", "type": "string" },
    { "key": "eventId",     "value": "EVT001",  "type": "string" },
    { "key": "chainId",     "value": "CHN001",  "type": "string" },
    { "key": "leadId",      "value": "LEAD001", "type": "string" },
    { "key": "taskId",      "value": "TASK001", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const body = pm.response.json();",
            "  pm.collectionVariables.set('accessToken',  body.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
            "  pm.collectionVariables.set('sessionId',    body.data.sessionId);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"owner@crm.vn\",\n  \"password\": \"crm@123456\"\n}" }
          },
          "response": []
        },
        {
          "name": "Login (as Manager)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const body = pm.response.json();",
            "  pm.collectionVariables.set('accessToken',  body.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
            "  pm.collectionVariables.set('sessionId',    body.data.sessionId);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"manager.cskh@crm.vn\",\n  \"password\": \"crm@123456\"\n}" }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const body = pm.response.json();",
            "  pm.collectionVariables.set('accessToken',  body.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth","refresh"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          },
          "response": []
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth","me"] }
          },
          "response": []
        },
        {
          "name": "Update Own Profile",
