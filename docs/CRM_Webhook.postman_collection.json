{
  "info": {
    "name": "CRM Webhook",
    "description": "Collection để test Webhook endpoints.\n\n**Setup:**\n1. Import collection này vào Postman\n2. Biến `webhookSecret` đã set sẵn (dev default)\n3. Chỉ cần bấm Send!\n\n**Lưu ý:** Đảm bảo server đang chạy tại `{{baseUrl}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "webhookSecret",
      "value": "whsec_dev_secret_key_change_in_production",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{webhookSecret}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "📥 Webhook Events",
      "item": [
        {
          "name": "new-registration — Khách hàng đăng ký mới",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Nguyễn Văn A\",\n    \"email\": \"nguyenvana@example.com\",\n    \"phone\": \"0901 234 567\",\n    \"source\": \"Website\",\n    \"address\": \"Hà Nội\"\n  },\n  \"tags\": [\"#trial\", \"#web\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/new-registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "new-registration"]
            },
            "description": "Tạo event khách hàng đăng ký mới.\n\nCRM sẽ tự động tạo Customer nếu chưa tồn tại."
          }
        },
        {
          "name": "new-registration — Với Assignee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Trần Thị B\",\n    \"email\": \"tranthib@example.com\",\n    \"phone\": \"0912 345 678\"\n  },\n  \"assignee\": {\n    \"email\": \"staff@company.com\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/new-registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "new-registration"]
            },
            "description": "Tạo event kèm assignee. CRM sẽ lookup staff theo email."
          }
        },
        {
          "name": "new-business — Tạo Business mới",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Nguyễn Văn A\",\n    \"email\": \"nguyenvana@example.com\"\n  },\n  \"biz\": {\n    \"id\": \"BIZ-12345\",\n    \"tags\": [\"ecommerce\", \"saas\"]\n  },\n  \"plan\": {\n    \"name\": \"TRIAL\",\n    \"cycle\": \"Thanh toán theo tháng\",\n    \"price\": \"0 đ\",\n    \"daysLeft\": 14,\n    \"expiryDate\": \"2026-05-06\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/new-business",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "new-business"]
            },
            "description": "Tạo event business mới. CRM sẽ liên kết Customer nếu tìm thấy."
          }
        },
        {
          "name": "expiring-subscription — Sắp hết hạn",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Nguyễn Văn A\",\n    \"email\": \"nguyenvana@example.com\"\n  },\n  \"biz\": {\n    \"id\": \"BIZ-12345\",\n    \"tags\": [\"ecommerce\"]\n  },\n  \"plan\": {\n    \"name\": \"PRO\",\n    \"daysLeft\": 3,\n    \"expiryDate\": \"2026-04-25\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/expiring-subscription",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "expiring-subscription"]
            },
            "description": "Tạo event business sắp hết hạn cần gia hạn."
          }
        },
        {
          "name": "upgrade-required — Cần nâng cấp",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Nguyễn Văn A\",\n    \"email\": \"nguyenvana@example.com\"\n  },\n  \"biz\": {\n    \"id\": \"BIZ-12345\"\n  },\n  \"plan\": {\n    \"name\": \"BASIC\",\n    \"cycle\": \"Thanh toán theo năm\",\n    \"price\": \"500.000 đ\"\n  },\n  \"quotas\": [\n    { \"name\": \"Users\", \"used\": 48, \"total\": 50, \"color\": \"red\" },\n    { \"name\": \"Storage\", \"used\": 9.5, \"total\": 10, \"color\": \"orange\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/upgrade-required",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "upgrade-required"]
            },
            "description": "Tạo event business cần nâng cấp gói cước."
          }
        }
      ],
      "description": "Các request gửi event vào CRM qua webhook."
    },
    {
      "name": "🛡️ Security Tests",
      "item": [
        {
          "name": "❌ Thiếu Authorization header",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": { \"name\": \"Test\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/new-registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "new-registration"]
            },
            "description": "Expect: `401 WEBHOOK_AUTH_REQUIRED`"
          }
        },
        {
          "name": "❌ Token sai",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "wrong_token", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": { \"name\": \"Test\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/new-registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "new-registration"]
            },
            "description": "Expect: `401 WEBHOOK_INVALID_TOKEN`"
          }
        }
      ],
      "description": "Test các trường hợp lỗi bảo mật."
    },
    {
      "name": "🔁 Idempotency Test",
      "item": [
        {
          "name": "Gửi lần 1 (success)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const fixedId = 'idempotency-test-' + Date.now();",
                  "pm.collectionVariables.set('idempotencyTestId', fixedId);",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Delivery-Id', value: fixedId });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lần 1 — 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Idempotency Test\",\n    \"email\": \"idempotency@test.com\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/new-registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "new-registration"]
            },
            "description": "Gửi lần đầu — expect `201`."
          }
        },
        {
          "name": "Gửi lần 2 (duplicate → 409)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const fixedId = pm.collectionVariables.get('idempotencyTestId');",
                  "if (!fixedId) throw new Error('Chạy \"Gửi lần 1\" trước!');",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Delivery-Id', value: fixedId });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lần 2 — 409 Duplicate', function() {",
                  "    pm.response.to.have.status(409);",
                  "    pm.expect(pm.response.json().code).to.eql('WEBHOOK_DUPLICATE_DELIVERY');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Idempotency Test\",\n    \"email\": \"idempotency@test.com\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/new-registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "new-registration"]
            },
            "description": "Gửi lại cùng delivery ID — expect `409`.\n\n⚠️ Phải chạy \"Gửi lần 1\" trước!"
          }
        }
      ],
      "description": "Test idempotency — gửi cùng delivery ID 2 lần."
    }
  ]
}
