              "raw": "{\n  \"eventType\": \"biz_moi\",\n  \"payload\": {\n    \"customer\": {\n      \"name\": \"Nguyễn Văn A\",\n      \"email\": \"nguyenvana@example.com\"\n    },\n    \"biz\": {\n      \"id\": \"BIZ-12345\",\n      \"tags\": [\"ecommerce\", \"saas\"]\n    },\n    \"plan\": {\n      \"name\": \"TRIAL\",\n      \"cycle\": \"Thanh toán theo tháng\",\n      \"price\": \"0 đ\",\n      \"daysLeft\": 14,\n      \"expiryDate\": \"2026-05-06\"\n    }\n  },\n  \"source\": \"postman-test\"\n}"
