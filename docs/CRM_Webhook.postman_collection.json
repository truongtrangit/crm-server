              "raw": "{\n  \"eventType\": \"sap_het_han\",\n  \"payload\": {\n    \"customer\": {\n      \"name\": \"Nguyễn Văn A\",\n      \"email\": \"nguyenvana@example.com\"\n    },\n    \"biz\": {\n      \"id\": \"BIZ-12345\",\n      \"tags\": [\"ecommerce\"]\n    },\n    \"plan\": {\n      \"name\": \"PRO\",\n      \"daysLeft\": 3,\n      \"expiryDate\": \"2026-04-25\"\n    }\n  },\n  \"source\": \"postman-test\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/ingest",
