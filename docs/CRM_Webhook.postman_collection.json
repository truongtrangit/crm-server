              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"can_nang_cap\",\n  \"payload\": {\n    \"customer\": {\n      \"name\": \"Nguyễn Văn A\",\n      \"email\": \"nguyenvana@example.com\"\n    },\n    \"biz\": {\n      \"id\": \"BIZ-12345\"\n    },\n    \"plan\": {\n      \"name\": \"BASIC\",\n      \"cycle\": \"Thanh toán theo năm\",\n      \"price\": \"500.000 đ\"\n    },\n    \"quotas\": [\n      { \"name\": \"Users\", \"used\": 48, \"total\": 50, \"color\": \"red\" },\n      { \"name\": \"Storage\", \"used\": 9.5, \"total\": 10, \"color\": \"orange\" }\n    ]\n  },\n  \"source\": \"postman-test\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "ingest"]
            },
            "description": "Tạo event `can_nang_cap` — business cần nâng cấp gói cước."
          },
          "response": []
        }
      ],
      "description": "Các request gửi event vào CRM qua webhook."
    },
    {
      "name": "🛡️ Security Tests",
      "item": [
        {
          "name": "❌ Thiếu Authorization header",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"user_moi\",\n  \"payload\": {\n    \"customer\": { \"name\": \"Test\" }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "ingest"]
            },
            "description": "Expect: `401 WEBHOOK_AUTH_REQUIRED`"
          },
          "response": []
        },
        {
          "name": "❌ Token sai",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "wrong_token_here",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"user_moi\",\n  \"payload\": {\n    \"customer\": { \"name\": \"Test\" }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "ingest"]
            },
            "description": "Expect: `401 WEBHOOK_INVALID_TOKEN`"
          },
          "response": []
        },
        {
          "name": "❌ Signature sai",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Override signature with invalid value",
                  "pm.request.headers.upsert({",
                  "    key: 'X-Webhook-Signature',",
                  "    value: 'sha256=invalid_signature_value'",
                  "});",
                  "pm.request.headers.upsert({",
                  "    key: 'X-Webhook-Delivery-Id',",
                  "    value: pm.variables.replaceIn('{{$guid}}')",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"user_moi\",\n  \"payload\": {\n    \"customer\": { \"name\": \"Test\" }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "ingest"]
            },
            "description": "Expect: `401 WEBHOOK_INVALID_SIGNATURE`"
          },
          "response": []
        },
        {
          "name": "❌ eventType không hợp lệ",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"invalid_event_type\",\n  \"payload\": {\n    \"customer\": { \"name\": \"Test\" }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "ingest"]
            },
            "description": "Expect: `400 VALIDATION_ERROR`"
          },
          "response": []
        },
        {
          "name": "❌ Thiếu payload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"user_moi\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "ingest"]
            },
            "description": "Expect: `400 VALIDATION_ERROR`"
          },
          "response": []
        }
      ],
      "description": "Test các trường hợp lỗi bảo mật — verify rằng webhook từ chối request không hợp lệ."
    },
    {
      "name": "🔁 Idempotency Test",
      "item": [
        {
          "name": "Gửi lần 1 (success)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Set fixed delivery ID for idempotency test",
                  "const fixedId = 'idempotency-test-' + Date.now();",
                  "pm.collectionVariables.set('idempotencyTestId', fixedId);",
                  "",
                  "const body = pm.request.body.raw;",
                  "const signingKey = pm.collectionVariables.get('webhookSigningKey');",
                  "const hmac = CryptoJS.HmacSHA256(body, signingKey).toString(CryptoJS.enc.Hex);",
                  "",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Signature', value: 'sha256=' + hmac });",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Delivery-Id', value: fixedId });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lần 1 — 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"user_moi\",\n  \"payload\": {\n    \"customer\": {\n      \"name\": \"Idempotency Test\",\n      \"email\": \"idempotency@test.com\"\n    }\n  },\n  \"source\": \"postman-idempotency\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "ingest"]
            },
            "description": "Gửi lần đầu — expect `201`.\n\nSau đó gửi request \"Gửi lần 2\" với cùng delivery ID."
          },
          "response": []
        },
        {
          "name": "Gửi lần 2 (duplicate → 409)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Reuse same delivery ID from lần 1",
                  "const fixedId = pm.collectionVariables.get('idempotencyTestId');",
                  "if (!fixedId) throw new Error('Chạy \"Gửi lần 1\" trước!');",
                  "",
                  "const body = pm.request.body.raw;",
                  "const signingKey = pm.collectionVariables.get('webhookSigningKey');",
                  "const hmac = CryptoJS.HmacSHA256(body, signingKey).toString(CryptoJS.enc.Hex);",
                  "",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Signature', value: 'sha256=' + hmac });",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Delivery-Id', value: fixedId });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lần 2 — 409 Duplicate', function() {",
                  "    pm.response.to.have.status(409);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.code).to.eql('WEBHOOK_DUPLICATE_DELIVERY');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"user_moi\",\n  \"payload\": {\n    \"customer\": {\n      \"name\": \"Idempotency Test\",\n      \"email\": \"idempotency@test.com\"\n    }\n  },\n  \"source\": \"postman-idempotency\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "ingest"]
            },
            "description": "Gửi lại với cùng delivery ID — expect `409 WEBHOOK_DUPLICATE_DELIVERY`.\n\n⚠️ Phải chạy \"Gửi lần 1\" trước!"
          },
          "response": []
        }
      ],
      "description": "Test cơ chế idempotency — gửi cùng delivery ID 2 lần.\n\n**Cách test:**\n1. Chạy \"Gửi lần 1\" → expect 201\n2. Chạy \"Gửi lần 2\" → expect 409"
    }
  ]
}
